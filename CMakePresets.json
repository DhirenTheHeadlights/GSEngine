{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "x64-clang-p2996-libcxx-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/Engine/External/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_C_COMPILER": "$env{CLANG_P2996_ROOT}/bin/clang.exe",
        "CMAKE_CXX_COMPILER": "$env{CLANG_P2996_ROOT}/bin/clang.exe",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "$env{CLANG_P2996_ROOT}/bin/clang-scan-deps.exe",
        "CMAKE_CXX_FLAGS_INIT": "-std=c++2c -freflection-latest --target=x86_64-pc-windows-msvc -mavx2",
        "CMAKE_CXX_MODULE_STD": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "PATH": "$env{CLANG_P2996_ROOT}/bin;$penv{PATH}"
      },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "inheritEnvironments": [ "msvc_x64_x64" ]
        }
      },
      "condition": {
        "type": "notEquals",
        "lhs": "$env{CLANG_P2996_ROOT}",
        "rhs": ""
      }
    },
    {
      "name": "x64-clang-p2996-libcxx-Debug",
      "displayName": "x64 clang-p2996 libc++ Debug",
      "inherits": "x64-clang-p2996-libcxx-base",
      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "VCPKG_TARGET_TRIPLET": "x64-windows-release",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg-overlays/triplets"
      }
    },
    {
      "name": "x64-clang-p2996-libcxx-Release",
      "displayName": "x64 clang-p2996 libc++ Release",
