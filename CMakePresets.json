          "inheritEnvironments": [ "msvc_x64_x64" ]
        }
      },
      "condition": {
        "type": "notEquals",
        "lhs": "$env{CLANG_P2996_ROOT}",
        "rhs": ""
      }
    },
    {
      "name": "x64-clang-p2996-libcxx-Debug",
      "displayName": "x64 clang-p2996 libc++ Debug",
      "inherits": "x64-clang-p2996-libcxx-base",
      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "x64-clang-p2996-libcxx-Release",
      "displayName": "x64 clang-p2996 libc++ Release",
      "inherits": "x64-clang-p2996-libcxx-base",
      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    {
