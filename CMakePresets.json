        "CMAKE_CXX_COMPILER": "$env{CLANG_P2996_ROOT}/bin/clang.exe",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "$env{CLANG_P2996_ROOT}/bin/clang-scan-deps.exe",
        "CMAKE_CXX_FLAGS_INIT": "-std=c++2c -freflection-latest --target=x86_64-pc-windows-msvc -mavx2",
        "CMAKE_CXX_MODULE_STD": "ON"
      },
      "environment": {
        "PATH": "$env{CLANG_P2996_ROOT}/bin;$penv{PATH}"
      },
      "vendor": {
