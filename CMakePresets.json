      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "x64-clang-p2996-libcxx-Release-trace",
      "displayName": "x64 clang-p2996 libc++ Release + ftime-trace + stats",
      "inherits": "x64-clang-p2996-libcxx-base",
      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Release-trace",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS_INIT": "-std=c++2c -freflection-latest --target=x86_64-pc-windows-msvc -mavx2 -ftime-trace -Xclang -print-stats"
      }
    },
    {
      "name": "x64-clang-p2996-libcxx-Debug-trace",
      "displayName": "x64 clang-p2996 libc++ Debug + ftime-trace + stats",
      "inherits": "x64-clang-p2996-libcxx-base",
      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Debug-trace",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "VCPKG_TARGET_TRIPLET": "x64-windows-release",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg-overlays/triplets",
        "CMAKE_CXX_FLAGS_INIT": "-std=c++2c -freflection-latest --target=x86_64-pc-windows-msvc -mavx2 -ftime-trace -Xclang -print-stats"
      }
    },
    {
      "name": "x64-clang-p2996-libcxx-Debug-asan",
      "displayName": "x64 clang-p2996 libc++ Debug + ASAN",
      "inherits": "x64-clang-p2996-libcxx-base",
      "binaryDir": "${sourceDir}/out/build/x64-clang-p2996-libcxx-Debug-asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "VCPKG_TARGET_TRIPLET": "x64-windows-release",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vcpkg-overlays/triplets",
        "CMAKE_CXX_FLAGS_INIT": "-std=c++2c -freflection-latest --target=x86_64-pc-windows-msvc -mavx2 -fsanitize=address -fno-omit-frame-pointer -g",
        "CMAKE_C_FLAGS_INIT": "--target=x86_64-pc-windows-msvc -fsanitize=address -fno-omit-frame-pointer -g",
        "CMAKE_EXE_LINKER_FLAGS_INIT": "-fsanitize=address",
        "CMAKE_SHARED_LINKER_FLAGS_INIT": "-fsanitize=address"
      }
    },
    {
      "name": "linux-gcc-trunk-Debug",
      "displayName": "Linux GCC trunk Debug (WSL)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-gcc-trunk-Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/Engine/External/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "CMAKE_C_COMPILER":   "$env{HOME}/gcc-trunk/bin/gcc",
        "CMAKE_CXX_COMPILER": "$env{HOME}/gcc-trunk/bin/g++",
        "CMAKE_CXX_FLAGS_INIT": "-std=c++26 -freflection -mavx2 -Wno-changes-meaning",
        "CMAKE_CXX_MODULE_STD": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "VULKAN_SDK": "$env{HOME}/vulkan-sdk/1.4.341.1/x86_64",
        "PATH": "$env{HOME}/vulkan-sdk/1.4.341.1/x86_64/bin:$penv{PATH}",
        "LD_LIBRARY_PATH": "$env{HOME}/vulkan-sdk/1.4.341.1/x86_64/lib:$penv{LD_LIBRARY_PATH}"
      }
    }
